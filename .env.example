# IBKR Connection Settings
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_IS_PAPER=true

# Account Management
IBKR_DEFAULT_ACCOUNT=
IBKR_MANAGED_ACCOUNTS=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/tmp/ibkr-mcp-server.log

# Reconnection Settings
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5

# Market Data Settings
IBKR_MARKET_DATA_TYPE=3

# Trading Safety Settings
ENABLE_LIVE_TRADING=false
MAX_ORDER_SIZE=1000
REQUIRE_ORDER_CONFIRMATION=true

# MCP Server Settings
MCP_SERVER_NAME=ibkr-mcp
MCP_SERVER_VERSION=1.0.0

# Layer 5b — HTTP transport (only used when running `--transport http`)
# Bind to 127.0.0.1 if accessed via SSH tunnel; bind to 0.0.0.0 (and SET
# MCP_AUTH_TOKEN) if exposing on a private network like Tailscale.
MCP_BIND_HOST=127.0.0.1
MCP_BIND_PORT=8765
# Strong random token (e.g. `openssl rand -hex 32`). REQUIRED if MCP_BIND_HOST
# is anything other than 127.0.0.1 — the daemon refuses to start otherwise.
MCP_AUTH_TOKEN=
