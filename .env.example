# IBKR Connection Settings
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_IS_PAPER=true

# Account Management
IBKR_DEFAULT_ACCOUNT=
IBKR_MANAGED_ACCOUNTS=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/tmp/ibkr-mcp-server.log

# Reconnection Settings
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=5

# Market Data Settings
IBKR_MARKET_DATA_TYPE=3

# Trading Safety Settings
ENABLE_LIVE_TRADING=false
MAX_ORDER_SIZE=1000
REQUIRE_ORDER_CONFIRMATION=true

# When true, tools that cancel orders, stop strategies, or transmit live
# orders return a "needs_confirmation" preview unless called with
# confirm=true. Prevents chat sessions from issuing destructive actions in
# one shot (e.g., "stop my F swing" wouldn't cancel protective stops
# without an explicit second call). Off by default — chat workflows expect
# single-shot tool calls.
REQUIRE_CONFIRMATION_FOR_DESTRUCTIVE_TOOLS=false

# MCP Server Settings
MCP_SERVER_NAME=ibkr-mcp
MCP_SERVER_VERSION=1.0.0

# Layer 5b — HTTP transport (only used when running `--transport http`)
# Bind to 127.0.0.1 if accessed via SSH tunnel; bind to 0.0.0.0 (and SET
# MCP_AUTH_TOKEN) if exposing on a private network like Tailscale.
MCP_BIND_HOST=127.0.0.1
MCP_BIND_PORT=8765
# Strong random token (e.g. `openssl rand -hex 32`). REQUIRED if MCP_BIND_HOST
# is anything other than 127.0.0.1 — the daemon refuses to start otherwise.
MCP_AUTH_TOKEN=

# Phone alerts via ntfy.sh — pushes a notification to the iOS/Android ntfy
# app on (a) IBKR disconnect, (b) IBKR reconnect, (c) daemon HTTP wedged
# (sent by scripts/ibkr-watchdog.sh, since a hung daemon can't notify itself).
#
# Setup:
#   1. Install the "ntfy" app on your phone (free, App Store / Play Store).
#   2. Pick an unguessable topic — anyone who knows it can read messages:
#        NTFY_TOPIC=ibkr-$(openssl rand -hex 4)
#   3. Subscribe to that topic in the app.
#   4. Set NOTIFY_ENABLED=true and restart the daemon.
#
# Override NTFY_URL only if you self-host ntfy.
NOTIFY_ENABLED=false
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=

# Layer 7 — in-house chat wrapper served at http://<host>:<port>/chat .
# Calls Anthropic API directly so the system prompt is fully ours and the
# consumer-product safety layer (which refuses to call destructive
# trading tools) is bypassed. Auth is the same MCP_AUTH_TOKEN.
#
# Get an API key at https://console.anthropic.com/ → Settings → API Keys.
# Set a $ spend cap on that console too — usage is metered.
CHAT_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Hard cap on the agentic loop (one Anthropic API call per iteration).
# Prevents a tool-call cycle from burning tokens forever.
CHAT_MAX_ITERATIONS=12
# Where the SQLite conversation store lives. Conversations persist
# across daemon restarts and can be reloaded from any device. The
# daemon creates this file on first use.
CHAT_DB_PATH=/home/trader/ibkr-mcp-server/chat.db

# Short PIN for unlocking the chat UI on new devices without pasting
# the full 64-char MCP_AUTH_TOKEN. 4 digits recommended (iOS shows
# the numeric keyboard). Leave blank to disable -- the chat UI will
# prompt for the full token instead.
#
# Rate limited to 5 attempts/minute; locked out for 1 hour after 10
# failed attempts within an hour (ntfy push fires on lockout).
CHAT_PIN=

# How often the daemon records a portfolio equity snapshot (used by
# the get_portfolio_equity_curve chart tool). 0 disables snapshotting.
# Default 3600s (1 hour) -- gives a useful equity curve without
# generating thousands of rows per day.
PORTFOLIO_SNAPSHOT_INTERVAL_SECONDS=3600
